{
  "version": 2,
  "builds": [
    {
      "src": "api-stream.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api-stream.js",
      "dest": "api-stream.js"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
